{
  "name": "@vuepress/theme-default",
  "version": "2.0.0-rc.130",
  "description": "Default theme of VuePress",
  "keywords": [
    "default",
    "theme",
    "vuepress",
    "vuepress-theme"
  ],
  "homepage": "https://ecosystem.vuejs.press/themes/default/",
  "bugs": {
    "url": "https://github.com/vuepress/ecosystem/issues"
  },
  "license": "MIT",
  "author": "meteorlxy",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vuepress/ecosystem.git",
    "directory": "themes/theme-default"
  },
  "files": [
    "dist",
    "templates"
  ],
  "type": "module",
  "sideEffects": [
    "./dist/client/components/**/*.vue",
    "./dist/client/layouts/*.vue",
    "./dist/client/styles/*.scss"
  ],
  "main": "./dist/node/index.js",
  "types": "./dist/node/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/node/index.d.ts",
      "default": "./dist/node/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "default": "./dist/client/index.js"
    },
    "./components/*": "./dist/client/components/*",
    "./layouts/*": "./dist/client/layouts/*",
    "./styles/*.scss": "./dist/client/styles/*.scss",
    "./styles/*": {
      "sass": "./dist/client/styles/*.scss"
    },
    "./templates/*": "./templates/*",
    "./dist/*": "./dist/*",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@vuepress/helper": "2.0.0-rc.130",
    "@vuepress/plugin-active-header-links": "2.0.0-rc.130",
    "@vuepress/plugin-back-to-top": "2.0.0-rc.130",
    "@vuepress/plugin-copy-code": "2.0.0-rc.130",
    "@vuepress/plugin-git": "2.0.0-rc.130",
    "@vuepress/plugin-links-check": "2.0.0-rc.130",
    "@vuepress/plugin-markdown-hint": "2.0.0-rc.130",
    "@vuepress/plugin-markdown-tab": "2.0.0-rc.130",
    "@vuepress/plugin-medium-zoom": "2.0.0-rc.130",
    "@vuepress/plugin-nprogress": "2.0.0-rc.130",
    "@vuepress/plugin-palette": "2.0.0-rc.130",
    "@vuepress/plugin-prismjs": "2.0.0-rc.130",
    "@vuepress/plugin-seo": "2.0.0-rc.130",
    "@vuepress/plugin-sitemap": "2.0.0-rc.130",
    "@vuepress/plugin-theme-data": "2.0.0-rc.130",
    "@vueuse/core": "^14.3.0",
    "vue": "^3.5.34"
  },
  "peerDependencies": {
    "sass": "^1.99.0",
    "sass-embedded": "^1.99.0",
    "sass-loader": "^16.0.8",
    "vuepress": "2.0.0-rc.30"
  },
  "peerDependenciesMeta": {
    "sass": {
      "optional": true
    },
    "sass-embedded": {
      "optional": true
    },
    "sass-loader": {
      "optional": true
    }
  },
  "gitHead": "3612bba34c7299f3bad032390904c8c27cd417cc"
}
